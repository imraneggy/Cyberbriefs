# ── CONTENT PROVIDER ──────────────────────────────────────────────────
# Choose the engine that generates post copy.
# Options:
#   openai          — original (paid, ~$0.01-0.05 per post)
#   github_models   — FREE in GitHub Actions (uses built-in GITHUB_TOKEN)
#   groq            — FREE tier (Llama 3.3 70B, 30 req/min) — needs GROQ_API_KEY
#   huggingface     — FREE tier (~100k tokens/day) — needs HUGGINGFACE_API_KEY
#   ollama          — 100% local + offline, free forever — needs Ollama running
#   test            — local SVG generator, no external calls (CI smoke test)
CONTENT_PROVIDER=github_models

# ── OLLAMA (only when CONTENT_PROVIDER=ollama) ────────────────────────
# Build the model first: ollama create cyberbriefs:latest -f local/cyberbriefs.Modelfile
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=cyberbriefs:latest

# ── IMAGE PROVIDER (used when CONTENT_PROVIDER is not openai or test) ─
# Options ranked by readable in-image text:
#   prompt_only   — NO image gen; Telegram delivers prompt + caption for you to
#                   generate the image manually (ChatGPT/Gemini/Midjourney).
#                   Use this with CONTENT_PROVIDER=ollama for 100% offline drafts.
#                   See docs/LOCAL_OLLAMA_DRAFT_MODE.md for setup.
#   composite     — FREE, always readable (PIL infographic template, no AI for text)
#   gemini        — REQUIRES BILLING (free tier image quota = 0)
#   recraft       — FREE 50/day (now needs card), BEST diffusion-text quality
#   nvidia        — FREE credits at signup, FLUX variants on NVIDIA NIM
#   pollinations  — truly FREE, no API key, FLUX-backed (weak text)
#   huggingface   — FREE (~50 imgs/hour), FLUX.1-schnell on HF
#   cloudflare    — FREE (10k req/day), SDXL Lightning on Workers AI
IMAGE_PROVIDER=composite
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
RECRAFT_API_KEY=
RECRAFT_MODEL=recraftv3
RECRAFT_STYLE=digital_illustration
NVIDIA_API_KEY=
NVIDIA_MODEL=black-forest-labs/flux.1-schnell

# Optional model overrides
GITHUB_MODELS_MODEL=openai/gpt-4o-mini
GROQ_MODEL=llama-3.3-70b-versatile
HUGGINGFACE_TEXT_MODEL=meta-llama/Llama-3.1-8B-Instruct
HUGGINGFACE_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
POLLINATIONS_MODEL=flux

# ── CAROUSEL ───────────────────────────────────────────────────────────
# Number of slides per post. 1 = single image (default). 2-10 = carousel.
# Carousels get 3-5× the engagement of single images on Instagram.
CAROUSEL_SLIDES=1

# ── DRAFTS PER RUN ─────────────────────────────────────────────────────
# How many independent drafts each workflow run produces. Used for "send
# me N options and I'll pick the best" flows. Defaults if unset:
#   MORNING_DRAFTS=3   EVENING_DRAFTS=2   → 5 total Telegram messages/day
MORNING_DRAFTS=3
EVENING_DRAFTS=2

# ── OPENAI (only needed when CONTENT_PROVIDER=openai) ──────────────────
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=low
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_OUTPUT_FORMAT=jpeg

# ── GROQ (only needed when CONTENT_PROVIDER=groq) ──────────────────────
GROQ_API_KEY=

# ── HUGGING FACE (text and/or image provider) ──────────────────────────
HUGGINGFACE_API_KEY=

# ── CLOUDFLARE WORKERS AI (image provider only) ────────────────────────
# These DOUBLE as Worker deploy creds; reused if you set IMAGE_PROVIDER=cloudflare.
CLOUDFLARE_API_TOKEN=

# ── TELEGRAM APPROVAL ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ── IMAGE STORAGE (no-card default uses GitHub public raw URLs) ────────
IMAGE_STORAGE_BACKEND=github
GITHUB_IMAGE_BRANCH=main
GITHUB_IMAGE_PATH_PREFIX=public/posts
GITHUB_IMAGE_PUBLIC_BASE_URL=

# Optional alternative: Cloudflare R2 (requires a payment method to create bucket).
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_BASE_URL=

# ── WORKER (Telegram webhook + IG publish) ─────────────────────────────
WORKER_BASE_URL=
WORKER_SHARED_SECRET=

# ── BRAND ──────────────────────────────────────────────────────────────
CYBERBRIEFS_TIMEZONE=Asia/Dubai
CYBERBRIEFS_BRAND_NAME=CyberBriefsDaily
CYBERBRIEFS_SITE_URL=
